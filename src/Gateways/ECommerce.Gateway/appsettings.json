{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp.ReverseProxy": "Information"
    }
  },

  "ReverseProxy": {
    "Routes": {
      "catalog-products-route": {
        "ClusterId": "catalog-cluster",
        "Match": {
          "Path": "/api/products/{**catch-all}"
        }
      },

      "identity-auth-route": {
        "ClusterId": "identityaccess-cluster",
        "Match": {
          "Path": "/api/v1/auth/{**catch-all}"
        }
      },

      "identity-users-route": {
        "ClusterId": "identityaccess-cluster",
        "Match": {
          "Path": "/api/v1/users/{**catch-all}"
        }
      },

      "identity-roles-route": {
        "ClusterId": "identityaccess-cluster",
        "Match": {
          "Path": "/api/v1/roles/{**catch-all}"
        }
      },

      "identity-permissions-route": {
        "ClusterId": "identityaccess-cluster",
        "Match": {
          "Path": "/api/v1/permissions/{**catch-all}"
        }
      }
    },

    "Clusters": {
      "catalog-cluster": {
        "Destinations": {
          "catalog-api": {
            "Address": "https://localhost:7204/"
          }
        }
      },

      "identityaccess-cluster": {
        "Destinations": {
          "identityaccess-api": {
            "Address": "https://localhost:7271/"
          }
        }
      }
    }
  },

  "AllowedHosts": "*"
}